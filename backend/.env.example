# Server
PORT=4000
CLIENT_URL=http://localhost:5173

# Database (SQLite by default - file path. Switch to a postgresql:// URL
# and change provider in prisma/schema.prisma for production hosting)
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# LLM (Anthropic Claude) - used for AI compatibility scoring.
# If left blank, the system automatically falls back to rule-based scoring.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Email (any free-tier SMTP provider, e.g. Gmail App Password, Brevo, Mailtrap)
# If left blank, emails are logged to the console instead of sent (dev fallback).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Rent & Flatmate Finder <no-reply@flatmatefinder.com>"

# Admin seed account (created by `npm run seed`)
ADMIN_EMAIL=admin@flatmatefinder.com
ADMIN_PASSWORD=Admin@12345
